# Copy to .env — never commit .env
# Get credentials: https://www.themoviedb.org/settings/api
#
# You can set the API key, the read access token, or both. If the token is set,
# requests use Authorization: Bearer (recommended). Otherwise the API key is sent as api_key.
EXPO_PUBLIC_TMDB_API_KEY=
EXPO_PUBLIC_TMDB_READ_ACCESS_TOKEN=
